# Data Workers — Environment Variables
# Copy to .env and fill in values for real infrastructure mode.
# When not set, agents use InMemory stubs (development/testing).

# ── Redis (IKeyValueStore) ──────────────────────────────────────────
# REDIS_URL=redis://localhost:6379/0
# REDIS_HOST=localhost
# REDIS_PORT=6379

# ── Kafka (IMessageBus) ────────────────────────────────────────────
# KAFKA_BROKERS=localhost:9092
# KAFKA_CLIENT_ID=data-workers
# KAFKA_GROUP_ID=data-workers-group

# ── PostgreSQL (IRelationalStore) ──────────────────────────────────
# DATABASE_URL=postgresql://dw_user:dw_local_dev@localhost:5432/data_workers
# PG_HOST=localhost
# PG_PORT=5432
# PG_DATABASE=data_workers
# PG_USER=dw_user
# PG_PASSWORD=dw_local_dev

# ── Neo4j (IGraphDB) ──────────────────────────────────────────────
# NEO4J_URI=bolt://localhost:7687
# NEO4J_USERNAME=neo4j
# NEO4J_PASSWORD=dw_local_dev

# ── pgvector (IVectorStore) ───────────────────────────────────────
# Requires DATABASE_URL + this flag:
# PGVECTOR_ENABLED=true
# PGVECTOR_DIMENSIONS=384

# ── PostgreSQL FTS (IFullTextSearch) ──────────────────────────────
# Requires DATABASE_URL + this flag:
# PG_FTS_ENABLED=true

# ── LLM Provider (ILLMClient) ────────────────────────────────────
# Set ONE of these to enable real LLM:
# ANTHROPIC_API_KEY=sk-ant-...
# OPENAI_API_KEY=sk-...
# OLLAMA_HOST=http://localhost:11434

# ── Warehouse (IWarehouseConnector) ──────────────────────────────
# WAREHOUSE_TYPE=snowflake
# SNOWFLAKE_ACCOUNT=...
# SNOWFLAKE_USERNAME=...
# SNOWFLAKE_PASSWORD=...

# ── Airflow (IOrchestratorAPI) ───────────────────────────────────
# AIRFLOW_URL=http://localhost:8080
# AIRFLOW_USERNAME=airflow
# AIRFLOW_PASSWORD=airflow

# ── Integration Tests ────────────────────────────────────────────
# INTEGRATION_TEST=true
