{
  "name": "data-context-mcp",
  "version": "0.1.0",
  "description": "Standalone MCP server for data context and catalog — search, lineage, docs, impact analysis",
  "type": "module",
  "bin": { "data-context-mcp": "./dist/index.js" },
  "main": "./dist/index.js",
  "files": ["dist", "README.md", "LICENSE"],
  "scripts": {
    "build": "tsup",
    "dev": "tsx watch src/index.ts",
    "test": "vitest run --passWithNoTests",
    "prepublishOnly": "npm run build"
  },
  "publishConfig": { "access": "public" },
  "keywords": ["mcp", "data-catalog", "data-context", "lineage", "data-engineering"],
  "license": "Apache-2.0",
  "engines": { "node": ">=20.0.0" },
  "dependencies": {
    "@data-workers/infrastructure-stubs": "*",
    "@data-workers/mcp-framework": "*",
    "@data-workers/agent-lifecycle": "*",
    "@data-workers/context-layer": "*",
    "@data-workers/validation": "*",
    "@data-workers/enterprise": "*",
    "@modelcontextprotocol/sdk": "^1.0.0"
  },
  "devDependencies": {
    "tsup": "^8.0.0",
    "tsx": "^4.0.0",
    "typescript": "^5.5.0",
    "vitest": "^1.0.0"
  }
}
